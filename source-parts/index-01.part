<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>잡히면 #윤밥사</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700;800&display=swap');
    :root {
      --ink: #f5f7ff;
      --muted: #a9b3ca;
      --panel: rgba(17, 22, 39, .82);
      --accent: #ffd84d;
      --danger: #ff6476;
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      margin: 0;
      display: grid;
      place-items: center;
      overflow: hidden;
      color: var(--ink);
      background:
        radial-gradient(circle at 50% 12%, rgba(67, 84, 139, .24), transparent 38%),
        linear-gradient(180deg, #090d18 0%, #03050a 100%);
      font-family: 'Nanum Gothic', sans-serif;
      touch-action: none;
    }
    .shell {
      width: min(1180px, 100vw);
      height: min(790px, 100vh);
      padding: 18px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 250px;
      gap: 16px;
    }
    .stage {
      position: relative;
      min-width: 0;
      border: 1px solid rgba(151, 177, 255, .22);
      border-radius: 22px;
      overflow: hidden;
      background: #050913;
      box-shadow: 0 26px 70px rgba(0, 0, 0, .5), inset 0 0 40px rgba(49, 79, 160, .08);
    }
    canvas { width: 100%; height: 100%; display: block; }
    .side {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .card {
      padding: 18px;
      border: 1px solid rgba(151, 177, 255, .18);
      border-radius: 18px;
      background: var(--panel);
      box-shadow: 0 18px 40px rgba(0,0,0,.24);
      backdrop-filter: blur(10px);
    }
    h1 { margin: 0 0 4px; font-size: 25px; line-height: 1.25; letter-spacing: -.6px; }
    .tagline { margin: 0; color: var(--muted); font-size: 13px; line-height: 1.55; }
    .stat { display:flex; align-items:baseline; justify-content:space-between; gap:12px; margin: 10px 0; }
    .stat span { color: var(--muted); font-size: 13px; }
    .stat strong { font-size: 22px; color: var(--accent); }
    .legend { display:grid; gap:10px; margin-top: 12px; }
    .legend-item { display:grid; grid-template-columns:34px 1fr; align-items:center; gap:10px; font-size:13px; line-height:1.35; }
    .avatar { width:34px; height:34px; border-radius:11px; display:grid; place-items:center; font-weight:800; color:#08101a; }
    .player { background:#f2d0b3; }
    .bear { background:#a96d3c; color:#fff; }
    .squirrel { background:#e99a43; color:#fff; }
    kbd {
      display:inline-grid; place-items:center; min-width:28px; height:28px; padding:0 7px;
      border:1px solid rgba(255,255,255,.2); border-bottom-width:3px; border-radius:7px;
      background:#141b2d; color:#fff; font-family:inherit; font-size:12px;
    }
    .keys { display:flex; flex-wrap:wrap; gap:6px; margin-top:10px; }
    button {
      width:100%; border:0; border-radius:13px; padding:13px 15px;
      background:linear-gradient(180deg,#ffe978,#f5bd28); color:#211600;
      font:800 15px 'Nanum Gothic',sans-serif; cursor:pointer;
      box-shadow:0 7px 0 #9b6a00, 0 14px 22px rgba(0,0,0,.22);
      transform:translateY(0); transition:.12s ease;
    }
    button:active { transform:translateY(4px); box-shadow:0 3px 0 #9b6a00,0 8px 12px rgba(0,0,0,.22); }
    .status { min-height:40px; margin:0; color:#dfe6fa; font-size:13px; line-height:1.5; }
    .dpad { display:none; grid-template-columns:repeat(3,56px); grid-template-rows:repeat(2,56px); justify-content:center; gap:6px; }
    .dpad button { height:56px; padding:0; box-shadow:none; background:#1b2440; color:#fff; font-size:22px; }
    .dpad .up { grid-column:2; }
    .dpad .left { grid-column:1; grid-row:2; }
    .dpad .down { grid-column:2; grid-row:2; }
    .dpad .right { grid-column:3; grid-row:2; }
    @media (max-width: 860px) {
      body { overflow:auto; }
      .shell { height:auto; min-height:100vh; grid-template-columns:1fr; padding:10px; }
      .stage { height:min(72vh, 680px); }
      .side { display:grid; grid-template-columns:1fr 1fr; }
      .dpad { display:grid; }
    }
